<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edvina Bahar</title>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;1,300;1,400&family=IBM+Plex+Mono:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #F5F2ED;
      --black: #0F0F0E;
      --ink: #1A1A18;
      --muted: #888882;
      --border: #D8D5CE;
      --sans: 'IBM Plex Sans', system-ui, sans-serif;
      --mono: 'IBM Plex Mono', monospace;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--black);
      font-family: var(--sans);
      font-size: 14px;
      line-height: 1.6;
      overflow-x: hidden;
    }

    a { color: inherit; text-decoration: none; }

    .page { display: none; }
    .page.active { display: block; }

    /* ── MAIN PAGE ── */
    #main-page {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 100vh;
    }

    /* LEFT PANEL */
    .left-panel {
      padding: 3rem 3rem 3rem 3.5rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      border-right: 1px solid var(--border);
      position: sticky;
      top: 0;
      height: 100vh;
    }

    .name-block { margin-bottom: 2rem; opacity: 0; animation: fadeIn 0.7s ease 0.1s forwards; }

    

    .name-text {}

    .name-large {
      font-size: clamp(1.6rem, 2.6vw, 2.5rem);
      font-weight: 400;
      letter-spacing: -0.03em;
      line-height: 1.05;
    }

    .name-underscore { color: var(--muted); }

    .tagline {
      font-size: 11px;
      color: var(--muted);
      font-family: var(--mono);
      margin-top: 0.5rem;
      line-height: 1.5;
    }

    .bio {
      font-size: 13px;
      line-height: 1.78;
      color: var(--ink);
      opacity: 0;
      animation: fadeIn 0.7s ease 0.35s forwards;
    }

    .skills-block {
      margin-top: 1.8rem;
      opacity: 0;
      animation: fadeIn 0.7s ease 0.5s forwards;
    }

    .skills-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.7rem;
    }

    .skills-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
    }

    .pill {
      font-family: var(--mono);
      font-size: 10px;
      padding: 3px 8px;
      border: 1px solid var(--border);
      color: var(--ink);
      letter-spacing: 0.02em;
    }

    .left-nav {
      margin-top: 1.8rem;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      opacity: 0;
      animation: fadeIn 0.7s ease 0.65s forwards;
    }

    .left-nav-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      color: var(--ink);
      cursor: pointer;
      background: none;
      border: none;
      padding: 0;
      font-family: var(--sans);
      text-align: left;
      width: fit-content;
      position: relative;
    }

    .left-nav-btn::after {
      content: '';
      position: absolute;
      bottom: -1px;
      left: 0;
      width: 0;
      height: 1px;
      background: var(--black);
      transition: width 0.2s ease;
    }

    .left-nav-btn:hover::after { width: 100%; }
    .left-nav-btn .arr { font-size: 11px; color: var(--muted); }

    .left-bottom {
      opacity: 0;
      animation: fadeIn 0.7s ease 0.8s forwards;
    }

    .coords {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      margin-bottom: 0.25rem;
    }

    .city { font-size: 12px; color: var(--muted); }

    /* RIGHT PANEL */
    .right-panel {
      padding: 3rem 3.5rem 3rem 3rem;
      overflow-y: auto;
    }

    .right-section {
      margin-bottom: 3.5rem;
      opacity: 0;
      animation: fadeIn 0.7s ease 0.4s forwards;
    }

    .right-section:nth-child(2) { animation-delay: 0.55s; }
    .right-section:nth-child(3) { animation-delay: 0.7s; }
    .right-section:nth-child(4) { animation-delay: 0.85s; }

    .section-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.2rem;
    }

    
    

    

    /* PROJECT ROWS */
    .project-row {
      display: grid;
      grid-template-columns: 3rem 1fr auto;
      align-items: start;
      gap: 1rem;
      padding: 1.2rem 0;
      border-top: 1px solid var(--border);
      cursor: pointer;
      color: var(--black);
      text-decoration: none;
    }

    .project-row:last-child { border-bottom: 1px solid var(--border); }
    .project-row:hover .project-name { text-decoration: underline; text-underline-offset: 3px; }

    .project-num {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      padding-top: 2px;
    }

    .project-name { font-size: 14px; font-weight: 400; line-height: 1.4; }

    .project-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      margin-top: 5px;
    }

    .tag {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
      padding: 2px 6px;
      border: 1px solid var(--border);
    }

    .project-arrow {
      font-size: 12px;
      color: var(--muted);
      padding-top: 3px;
      transition: transform 0.15s, color 0.15s;
    }

    .project-row:hover .project-arrow {
      transform: translate(2px, -2px);
      color: var(--black);
    }

    /* EXPERIENCE ROWS */
    .exp-row {
      display: grid;
      grid-template-columns: 3rem 1fr;
      gap: 1rem;
      padding: 1.2rem 0;
      border-top: 1px solid var(--border);
      cursor: pointer;
      transition: opacity 0.15s;
    }

    .exp-row:last-child { border-bottom: 1px solid var(--border); }
    .exp-row:hover { opacity: 0.55; }

    .exp-num {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      padding-top: 2px;
    }

    .exp-name { font-size: 14px; font-weight: 400; }

    .exp-sub {
      font-size: 11px;
      color: var(--muted);
      margin-top: 3px;
      font-family: var(--mono);
    }

    /* NETWORK */
    .network-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem 1.8rem;
    }

    .net-link {
      font-size: 13px;
      color: var(--ink);
      position: relative;
    }

    .net-link::after {
      content: '';
      position: absolute;
      bottom: -1px;
      left: 0;
      width: 0;
      height: 1px;
      background: var(--black);
      transition: width 0.2s ease;
    }

    .net-link:hover::after { width: 100%; }

    .copyright {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
      padding-top: 3rem;
      padding-bottom: 1rem;
    }

    /* ── INNER PAGES ── */
    .inner-page { min-height: 100vh; padding: 3rem 3.5rem; }

    .inner-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 3rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--border);
    }

    .inner-title {
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      font-weight: 400;
      letter-spacing: -0.025em;
    }

    .back-btn {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      background: none;
      border: none;
      cursor: pointer;
      transition: color 0.2s;
    }

    .back-btn:hover { color: var(--black); }

    .exp-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1px;
      background: var(--border);
    }

    .exp-card {
      background: var(--bg);
      padding: 2rem 1.6rem;
      min-height: 160px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      transition: background 0.2s, color 0.2s;
      cursor: default;
    }

    .exp-card:hover { background: var(--black); color: var(--bg); }
    .exp-card-name { font-size: 15px; font-weight: 400; line-height: 1.35; }

    .exp-card-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      margin-top: 0.8rem;
      transition: color 0.2s;
    }

    .exp-card:hover .exp-card-label { color: #aaa; }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 768px) {
      #main-page { grid-template-columns: 1fr; }
      .left-panel {
        position: static;
        height: auto;
        border-right: none;
        border-bottom: 1px solid var(--border);
        padding: 2rem 1.5rem;
      }
      .right-panel { padding: 2rem 1.5rem; }
      .inner-page  { padding: 2rem 1.5rem; }
      
    }
  </style>
</head>
