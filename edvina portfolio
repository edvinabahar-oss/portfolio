  <!-- CONTACT PAGE -->
  <div id="contact-page" class="page inner-page">
    <div class="inner-header">
      <h1 class="inner-title">Contact_</h1>
      <button class="back-btn" onclick="showPage('home-page')">&#8592; Back</button>
    </div>
    <div class="contact-list">
      <div class="contact-row">
        <span class="contact-label">Email</span>
