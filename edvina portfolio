<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edvina Bahar</title>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;1,300;1,400&family=IBM+Plex+Mono:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #F5F2ED;
      --black: #0F0F0E;
      --ink: #1A1A18;
      --muted: #888882;
      --border: #D8D5CE;
      --sans: 'IBM Plex Sans', system-ui, sans-serif;
      --mono: 'IBM Plex Mono', monospace;
    }

    body {
      background: var(--bg);
      color: var(--black);
      font-family: var(--sans);
      font-size: 14px;
      line-height: 1.6;
      overflow-x: hidden;
    }

    a { color: inherit; text-decoration: none; }

    /* ── PAGE SYSTEM ── */
    .page { display: none; min-height: 100vh; }
    .page.active { display: flex; flex-direction: column; }

    /* ── HAMBURGER MENU ── */
    #menu-btn {
      position: fixed;
      top: 1.6rem;
      left: 1.8rem;
      z-index: 100;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      display: flex;
      flex-direction: column;
      gap: 5px;
      width: 28px;
    }

    #menu-btn span {
      display: block;
      height: 1px;
      background: var(--black);
      transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
      transform-origin: left center;
    }

    #menu-btn span:nth-child(1) { width: 28px; }
    #menu-btn span:nth-child(2) { width: 20px; }
    #menu-btn span:nth-child(3) { width: 24px; }

    body.menu-open #menu-btn span:nth-child(1) { transform: rotate(38deg) translateY(-1px); width: 28px; }
    body.menu-open #menu-btn span:nth-child(2) { opacity: 0; transform: scaleX(0); }
    body.menu-open #menu-btn span:nth-child(3) { transform: rotate(-38deg) translateY(1px); width: 28px; }

    /* ── MENU OVERLAY ── */
    #menu-overlay {
      position: fixed;
      inset: 0;
      z-index: 90;
      background: var(--bg);
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 0 3.5rem;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }

    body.menu-open #menu-overlay {
      opacity: 1;
      pointer-events: all;
    }

    .menu-items {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }

    .menu-item {
      font-size: 13px;
      font-weight: 400;
      letter-spacing: 0;
      color: var(--black);
      background: none;
      border: none;
      cursor: pointer;
      font-family: var(--sans);
      text-align: left;
      padding: 0.35rem 0;
      position: relative;
      width: fit-content;
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.3s ease, transform 0.3s ease, color 0.2s;
    }

    body.menu-open .menu-item { opacity: 1; transform: translateY(0); }
    body.menu-open .menu-item:nth-child(1) { transition-delay: 0.05s; }
    body.menu-open .menu-item:nth-child(2) { transition-delay: 0.1s; }
    body.menu-open .menu-item:nth-child(3) { transition-delay: 0.15s; }
    body.menu-open .menu-item:nth-child(4) { transition-delay: 0.2s; }

    .menu-item:hover { color: var(--muted); }

    .menu-num {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
      vertical-align: middle;
      margin-right: 0.5rem;
      font-weight: 400;
    }

    .menu-footer {
      position: absolute;
      bottom: 2.5rem;
      left: 3.5rem;
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 0.1em;
    }

    /* ── HOME PAGE ── */
    #home-page {
      padding: 5rem 3.5rem 3rem;
      justify-content: space-between;
      align-items: center;
      text-align: center;
    }

    .home-top { display: flex; flex-direction: column; align-items: center; }

    .name-block {
      margin-bottom: 2.5rem;
      opacity: 0;
      animation: fadeIn 0.6s ease 0.15s forwards;
    }

    .name-large {
      font-size: clamp(2rem, 4vw, 3.2rem);
      font-weight: 400;
      letter-spacing: -0.03em;
      line-height: 1.05;
    }

    .name-underscore { color: var(--muted); }

    .tagline {
      font-size: 11px;
      color: var(--muted);
      font-family: var(--mono);
      margin-top: 0.6rem;
      line-height: 1.6;
    }

    .bio {
      max-width: 540px;
      font-size: 13.5px;
      line-height: 1.78;
      color: var(--ink);
      opacity: 0;
      animation: fadeIn 0.7s ease 0.35s forwards;
    }

    .skills-block {
      margin-top: 2rem;
      max-width: 540px;
      opacity: 0;
      animation: fadeIn 0.7s ease 0.5s forwards;
    }

    .skills-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.7rem;
    }

    .skills-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
      justify-content: center;
    }

    .pill {
      font-family: var(--mono);
      font-size: 10px;
      padding: 3px 8px;
      border: 1px solid var(--border);
      color: var(--ink);
      letter-spacing: 0.02em;
    }

    .home-nav {
      margin-top: 2.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.45rem;
      opacity: 0;
      animation: fadeIn 0.7s ease 0.65s forwards;
    }

    .home-nav-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      color: var(--ink);
      cursor: pointer;
      background: none;
      border: none;
      padding: 0;
      font-family: var(--sans);
      text-align: left;
      width: fit-content;
      position: relative;
    }

    .home-nav-btn::after {
      content: '';
      position: absolute;
      bottom: -1px;
      left: 0;
      width: 0;
      height: 1px;
      background: var(--black);
      transition: width 0.2s ease;
    }

    .home-nav-btn:hover::after { width: 100%; }
    .home-nav-btn .arr { font-size: 11px; color: var(--muted); }

    .home-bottom {
      opacity: 0;
      animation: fadeIn 0.7s ease 0.8s forwards;
      text-align: center;
    }

    .coords {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      margin-bottom: 0.25rem;
    }

    .city { font-size: 12px; color: var(--muted); }

    /* ── INNER PAGES ── */
    .inner-page { padding: 5rem 3.5rem 3rem; }

    .inner-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 3rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--border);
    }

    .inner-title {
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      font-weight: 400;
      letter-spacing: -0.025em;
    }

    .back-btn {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      background: none;
      border: none;
      cursor: pointer;
      transition: color 0.2s;
    }

    .back-btn:hover { color: var(--black); }

    .section-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.2rem;
    }

    /* PROJECT ROWS */
    .project-row {
      display: grid;
      grid-template-columns: 3rem 1fr auto;
      align-items: start;
      gap: 1rem;
      padding: 1.2rem 0;
      border-top: 1px solid var(--border);
      cursor: pointer;
      color: var(--black);
      text-decoration: none;
    }

    .project-row:last-child { border-bottom: 1px solid var(--border); }
    .project-row:hover .project-name { text-decoration: underline; text-underline-offset: 3px; }

    .project-num {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      padding-top: 2px;
    }

    .project-name { font-size: 14px; font-weight: 400; line-height: 1.4; }

    .project-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 5px; }

    .tag {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
      padding: 2px 6px;
      border: 1px solid var(--border);
    }

    .project-arrow {
      font-size: 12px;
      color: var(--muted);
      padding-top: 3px;
      transition: transform 0.15s, color 0.15s;
    }

    .project-row:hover .project-arrow { transform: translate(2px, -2px); color: var(--black); }

    /* EXPERIENCE CARDS */
    .exp-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1px;
      background: var(--border);
    }

    .exp-card {
      background: var(--bg);
      padding: 2rem 1.6rem;
      min-height: 160px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      transition: background 0.2s, color 0.2s;
      cursor: default;
      text-decoration: none;
      color: var(--black);
    }

    .exp-card:hover { background: var(--black); color: var(--bg); }
    .exp-card-name { font-size: 15px; font-weight: 400; line-height: 1.35; }

    .exp-card-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      margin-top: 0.8rem;
      transition: color 0.2s;
    }

    .exp-card:hover .exp-card-label { color: #aaa; }

    /* ABOUT PAGE */
    .about-content {
      max-width: 600px;
    }

    .about-content p {
      font-size: 14px;
      line-height: 1.85;
      color: var(--ink);
      margin-bottom: 1.5rem;
    }

    /* CONTACT PAGE */
    .contact-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .contact-row {
      display: grid;
      grid-template-columns: 8rem 1fr;
      align-items: center;
      padding: 1.2rem 0;
      border-top: 1px solid var(--border);
      font-size: 13px;
    }

    .contact-row:last-child { border-bottom: 1px solid var(--border); }

    .contact-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .contact-val {
      color: var(--ink);
      position: relative;
      width: fit-content;
    }

    .contact-val::after {
      content: '';
      position: absolute;
      bottom: -1px;
      left: 0;
      width: 0;
      height: 1px;
      background: var(--black);
      transition: width 0.2s;
    }

    .contact-val:hover::after { width: 100%; }

    .copyright {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
      margin-top: auto;
      padding-top: 3rem;
      padding-bottom: 1rem;
    }

    /* ── ANIMATIONS ── */
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 600px) {
      #home-page, .inner-page { padding: 4.5rem 1.5rem 2rem; }
      #menu-btn { left: 1.2rem; top: 1.2rem; }
      #menu-overlay { padding: 0 1.5rem; }
      .menu-footer { left: 1.5rem; }
    }
  </style>
</head>
<body>

  <!-- HAMBURGER BUTTON -->
  <button id="menu-btn" aria-label="Toggle menu" onclick="toggleMenu()">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <!-- MENU OVERLAY -->
