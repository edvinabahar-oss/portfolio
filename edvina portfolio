      </div>
      <div class="contact-row">
        <span class="contact-label">LinkedIn</span>
        <a href="https://linkedin.com" target="_blank" rel="noopener" class="contact-val">linkedin.com/in/edvinabahar</a>
      </div>
      <div class="contact-row">
        <span class="contact-label">Location</span>
        <span class="contact-val" style="cursor:default;">San Francisco, CA</span>
      </div>
    </div>
    <div class="copyright">&#169; 2026 Edvina Bahar</div>
  </div>

  <script>
    function showPage(id) {
      document.querySelectorAll('.page').forEach(p => {
        p.classList.remove('active');
        p.style.display = 'none';
      });
      const target = document.getElementById(id);
      target.style.display = 'flex';
      target.classList.add('active');
      window.scrollTo(0, 0);
    }

    function toggleMenu() {
      document.body.classList.toggle('menu-open');
    }

    function navTo(id) {
      document.body.classList.remove('menu-open');
      // small delay so menu closes before page switches
      setTimeout(() => showPage(id), 200);
    }

    // init: hide all but home
    document.querySelectorAll('.page').forEach(p => {
      if (!p.classList.contains('active')) p.style.display = 'none';
    });
  </script>
</body>
</html>
